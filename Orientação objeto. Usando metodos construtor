public class ExemploOO1 {

    public static void main(String[] args) {
        System.out.println("\n\nVamos fazer a primeira criação de um objeto\n");
       //criação de um objeto de uma classe
      Retangulo campo1 = new Retangulo();
       Retangulo campo2 = new Retangulo(3.7, 3.5);
        Retangulo campo3 = new Retangulo(5, 9);
         Retangulo campo4 = new Retangulo(6.7, 8);
        System.out.println("Area 1: " + campo1.getArea());
        System.out.println("Area 2: " + campo2.getArea());
        System.out.println("Area 3: " + campo3.getArea());
        System.out.println("Area 4: " + campo4.getArea());
    }
    
}

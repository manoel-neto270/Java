class Retangulo{
    private double comprimento;
    private double largura;
    
    //Metodo construtor #1
    public Retangulo(){
        System.out.println("Construtor sem parametro");
        this.comprimento = 10.0;
        this.largura = 46.0;
    }
    //Metodo construtor #2;
    public Retangulo(double c, double l){
        System.out.println("Construtor somente double");
        comprimento = c;
        largura = l;
    }
    //Metodo construtor #3;
      public Retangulo(int c, int l){
        System.out.println("Construtor somente int");
        comprimento = c;
        largura = l;
    }
      //Metodo construtor #4
       public Retangulo(double c, int l){
        System.out.println("Construtor com double e int");
        comprimento = c;
        largura = l;
    }
    
    public void setComprimento(double c){
        comprimento = c;
        
    }
   public void setLargura(double l){
            largura = l;
    }
    public double getArea(){
        return comprimento * largura;
    }
    public double getLargura(){
        return largura;
    }
    public double getComprimento(){
        return comprimento;
    }
    
}
